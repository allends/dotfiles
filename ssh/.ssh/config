# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

Host *
	IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

Host github.com
	HostName github.com
	User git

# Reverse tunnel from work MBP back to Fedora home.
# Start with: ssh home-reverse-tunnel
# This exposes the MBP's SSH server on Fedora localhost:2223.
Host home-reverse-tunnel
	HostName 71.105.200.114
	User allen
	Port 2222
	ServerAliveInterval 30
	ServerAliveCountMax 3
	ExitOnForwardFailure yes
	RemoteForward 2223 localhost:22

Host home-vps-bastion
	HostName 167.88.42.49
	Port 22222
	User allen
	IdentityFile ~/.ssh/hermes_reverse_tunnel
	IdentitiesOnly yes

Host fedora-via-vps
	HostName 127.0.0.1
	Port 8022
	User allen
	IdentityFile ~/.ssh/hermes_reverse_tunnel
	IdentitiesOnly yes
	ProxyCommand ssh -i ~/.ssh/hermes_reverse_tunnel -p 22222 -o IdentitiesOnly=yes -W %h:%p allen@167.88.42.49
