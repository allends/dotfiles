// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "open_ai_compatible_api": {
      "model": ""
    }
  },
  "bottom_dock_layout": "contained",
  "project_panel": {
    "dock": "left",
    "button": true,
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 16
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false
  },
  "git_panel": {
    "dock": "left"
  },
  "chat_panel": {
    "button": "never"
  },
  "notification_panel": {
    "button": false
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": true
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "close_position": "right",
    "show_close_button": "always"
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_picture": false
  },
  "centered_layout": {
    "left_padding": 0.0,
    "right_padding": 0.0
  },
  "vim_mode": false,
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "tasks": {
    "prefer_lsp": true
  },
  "lsp_document_colors": "inlay",
  "git": {
    "inline_blame": {
      "enabled": true,
    },
    "enable_status": true,
  },
  "helix_mode": true,
  "agent": {
    "button": false,
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-7-latest",
      "enable_thinking": false
    },
    "dock": "right",
    "tool_permissions": {
      "tools": {
        "fetch": {
          "default": "allow"
        },
        "terminal": {
          "default": "allow"
        }
      }
    },
    "default_profile": "write",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "anthropic",
      "model": "claude-opus-4-7-latest",
    },
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "VSCode Icons for Zed (Dark)",
  },
  "base_keymap": "Cursor",
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "VSCode Light+",
    "dark": "VSCode Dark Modern",
  },
  "terminal": {
    "dock": "bottom",
    "font_family": "JetBrainsMono Nerd Font Mono"
  },
  "show_completions_on_input": true,
  "show_edit_predictions": true,
  "formatter": "language_server",
  "lsp": {
    "pyright": {
      "settings": {
        "python.analysis": {
          "autoImportCompletions": true,
          "diagnosticMode": "workspace"
        }
      }
    }
  },
  "languages": {
    "TypeScript": {
      "language_servers": [
        "tsgo",
        "!typescript-language-server",
        "!vtsls"
      ]
    },
    "TSX": {
      "language_servers": [
        "tsgo",
        "!typescript-language-server",
        "!vtsls"
      ]
    },
    "JavaScript": {
      "language_servers": [
        "tsgo",
        "!typescript-language-server",
        "!vtsls"
      ]
    }
  }
}
